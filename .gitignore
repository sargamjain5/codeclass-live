# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ------------------------------------------------------------------------------
# DEPENDENCIES
# ------------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------------------------------------------------------
# NEXT.JS & BUILD OUTPUTS
# ------------------------------------------------------------------------------
/.next/
/out/
/build
/coverage
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------------------------
# LOCAL EXECUTION (DOCKER TEMP FILES)
# ------------------------------------------------------------------------------
# This prevents student code snippets from being pushed to your repo
/temp/
/temp_exec/

# ------------------------------------------------------------------------------
# ENVIRONMENT SECRETS (CRITICAL)
# ------------------------------------------------------------------------------
# Protects your ZegoCloud AppID and Server Secret
.env
.env.local
.env.production
.env.test
.env*.local

# ------------------------------------------------------------------------------
# MISC / DEBUG
# ------------------------------------------------------------------------------
.DS_Store
*.pem
.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*